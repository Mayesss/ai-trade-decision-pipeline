{
  "name": "my-vercel-api-ts",
  "version": "1.0.0",
  "type": "module",
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@prisma/client": "^6.16.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^24.10.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "ag-grid-community": "^35.1.0",
    "ag-grid-react": "^35.1.0",
    "lightweight-charts": "^5.0.9",
    "lucide-react": "^0.561.0",
    "next": "^16.0.7",
    "pg": "^8.20.0",
    "postcss": "^8.5.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "db:pg:generate": "node scripts/with-db-env.mjs prisma generate",
    "db:pg:validate": "node scripts/with-db-env.mjs prisma validate",
    "db:pg:migrate:deploy": "node scripts/with-db-env.mjs prisma migrate deploy",
    "db:pg:health": "node scripts/with-db-env.mjs node --import tsx scripts/scalp-pg-healthcheck.ts",
    "test:ts": "node --import tsx --test",
    "test:forex": "node --import tsx --test lib/forex/*.test.ts lib/forex/modules/*.test.ts lib/forex/replay/*.test.ts",
    "test:scalp": "node --import tsx --test lib/scalp/replay/*.test.ts lib/scalp/strategies/*.test.ts lib/scalp/evidence/*.test.ts lib/scalp/regimes/*.test.ts lib/scalp/research/*.test.ts",
    "backtest:scalp:profiles": "node --import tsx scripts/scalp-backtest-profiles.ts",
    "backtest:scalp:deployments": "node --import tsx scripts/scalp-deployment-matrix.ts",
    "scalp:sync-candles-kv": "node --import tsx scripts/scalp-sync-candles-kv.ts",
    "scalp:research:sunday": "node scripts/with-db-env.mjs node --import tsx scripts/scalp-research-sunday.ts",
    "scalp:composer:pattern-evidence": "node scripts/with-db-env.mjs node --import tsx scripts/scalp-composer-pattern-evidence.ts --backfill --aggregate --bucketMinutes 60",
    "scalp:regimes:build": "node scripts/with-db-env.mjs node --import tsx scripts/scalp-regimes-build.ts",
    "scalp:regimes:backfill": "node scripts/with-db-env.mjs node --import tsx scripts/scalp-regimes-backfill-walkforward.ts",
    "scalp:regimes:reevaluate": "node scripts/with-db-env.mjs node --import tsx scripts/scalp-regimes-reevaluate-envelopes.ts",
    "scalp:regimes:backfill-incremental": "node scripts/with-db-env.mjs node --import tsx scripts/scalp-regimes-backfill-incremental-state.ts",
    "bulk:research": "node --import tsx scripts/research-local-bulk.ts",
    "bulk:research:regimes": "BULK_RESEARCH_VERSION=regimes BULK_RUN_REGIME_WALKFORWARD=1 node --import tsx scripts/research-local-bulk.ts",
    "bulk:research:promote": "BULK_RESEARCH_VERSION=research node --import tsx scripts/research-local-bulk.ts"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "baseline-browser-mapping": "^2.9.19",
    "prisma": "^6.16.0",
    "tsx": "^4.21.0"
  },
  "overrides": {
    "pg-cloudflare": "file:stubs/pg-cloudflare"
  }
}
