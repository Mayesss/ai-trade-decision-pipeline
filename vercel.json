{
  "version": 2,
  "builds": [
    { "src": "package.json", "use": "@vercel/next" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" }
  ],
  "crons": [
    { "path": "/api/swing/analyze?symbol=BTCUSDT&platform=bitget&newsSource=coindesk&category=crypto&dryRun=false&decisionPolicy=balanced", "schedule": "0 * * * *" },
    { "path": "/api/swing/analyze?symbol=GOLD&platform=capital&newsSource=marketaux&category=commodity&dryRun=false&decisionPolicy=balanced", "schedule": "0 * * * *" },
    { "path": "/api/swing/analyze?symbol=OIL_CRUDE&platform=capital&newsSource=marketaux&category=commodity&dryRun=false&decisionPolicy=balanced", "schedule": "0 * * * *" },
    { "path": "/api/swing/analyze?symbol=COFFEEARABICA&platform=capital&newsSource=marketaux&category=commodity&dryRun=false&decisionPolicy=balanced", "schedule": "0 * * * *" },
    { "path": "/api/scalp/cron/orchestrate-pipeline?maxDurationMs=600000&selfInvokeOnContinue=true", "schedule": "45 2,14 * * *" },
    { "path": "/api/scalp/cron/orchestrate-pipeline?continue=1&maxDurationMs=600000&selfInvokeOnContinue=false", "schedule": "*/5 * * * *" },
    { "path": "/api/scalp/cron/research-report?dryRun=false", "schedule": "0 * * * *" },
    { "path": "/api/scalp/cron/live-guardrail-monitor?dryRun=false&autoPause=true", "schedule": "*/15 * * * *" },
    { "path": "/api/scalp/cron/housekeeping?dryRun=false&refreshReport=true&candleHistoryKeepWeeks=14", "schedule": "5 * * * *" },
    { "path": "/api/scalp/cron/execute-deployments?all=true&dryRun=false&requirePromotionEligible=true", "schedule": "* * * * *" }
  ]
}
