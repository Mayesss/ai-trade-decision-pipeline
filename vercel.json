{
  "version": 2,
  "builds": [
    { "src": "package.json", "use": "@vercel/next" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" }
  ],
  "crons": [
    { "path": "/api/swing/analyze?symbol=BTCUSDT&platform=bitget&newsSource=coindesk&category=crypto&dryRun=false&decisionPolicy=balanced", "schedule": "0 * * * *" },
    { "path": "/api/swing/analyze?symbol=GOLD&platform=capital&newsSource=marketaux&category=commodity&dryRun=false&decisionPolicy=balanced", "schedule": "0 * * * *" },
    { "path": "/api/swing/analyze?symbol=OIL_CRUDE&platform=capital&newsSource=marketaux&category=commodity&dryRun=false&decisionPolicy=balanced", "schedule": "0 * * * *" },
    { "path": "/api/swing/analyze?symbol=COFFEEARABICA&platform=capital&newsSource=marketaux&category=commodity&dryRun=false&decisionPolicy=balanced", "schedule": "0 * * * *" },
    { "path": "/api/scalp/cron/discover-symbols?dryRun=false&includeLiveQuotes=true&seedTopSymbols=12&seedChunkDays=10&seedTargetHistoryDays=90&seedMaxRequestsPerSymbol=40&seedMaxSymbolsPerRun=12", "schedule": "15 2 * * 1" },
    { "path": "/api/scalp/cron/discover-symbols?dryRun=false&includeLiveQuotes=true&seedTopSymbols=4&seedChunkDays=3&seedTargetHistoryDays=90&seedMaxRequestsPerSymbol=20&seedMaxSymbolsPerRun=4", "schedule": "10 1 * * 2-5" },
    { "path": "/api/scalp/cron/discover-symbols?dryRun=false&includeLiveQuotes=false&seedTopSymbols=4&seedChunkDays=3&seedTargetHistoryDays=90&seedMaxRequestsPerSymbol=20&seedMaxSymbolsPerRun=4", "schedule": "10 1 * * 0,6" },
    { "path": "/api/scalp/cron/research-cycle-start?dryRun=false&force=false", "schedule": "45 2 * * 1" },
    { "path": "/api/scalp/cron/research-cycle-worker?maxRuns=2&aggregateAfter=false&finalizeWhenDone=true&syncPromotionGates=false&requireCompletedCycleForSync=false", "schedule": "*/2 * * * *" },
    { "path": "/api/scalp/cron/research-cycle-aggregate?finalizeWhenDone=true", "schedule": "*/10 * * * *" },
    { "path": "/api/scalp/cron/research-cycle-sync-gates?dryRun=false&requireCompletedCycle=true", "schedule": "*/20 * * * *" },
    { "path": "/api/scalp/cron/research-report?dryRun=false", "schedule": "0 * * * *" },
    { "path": "/api/scalp/cron/live-guardrail-monitor?dryRun=false&autoPause=true", "schedule": "*/15 * * * *" },
    { "path": "/api/scalp/cron/housekeeping?dryRun=false&refreshReport=true", "schedule": "5 * * * *" },
    { "path": "/api/scalp/cron/execute-deployments?all=true&dryRun=false&requirePromotionEligible=true", "schedule": "* * * * *" }
  ]
}
