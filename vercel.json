{
  "version": 2,
  "builds": [{ "src": "package.json", "use": "@vercel/next" }],
  "routes": [{ "src": "/api/(.*)", "dest": "/api/$1" }],
  "crons": [
    {
      "path": "/api/swing/analyze?symbol=BTCUSDT&platform=bitget&newsSource=coindesk&category=crypto&dryRun=false&decisionPolicy=balanced",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/swing/analyze?symbol=GOLD&platform=capital&newsSource=marketaux&category=commodity&dryRun=false&decisionPolicy=balanced",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/swing/analyze?symbol=OIL_CRUDE&platform=capital&newsSource=marketaux&category=commodity&dryRun=false&decisionPolicy=balanced",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/swing/analyze?symbol=COFFEEARABICA&platform=capital&newsSource=marketaux&category=commodity&dryRun=false&decisionPolicy=balanced",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/scalp/v2/cron/cycle?dryRun=false&batchSize=100&autoContinue=true&selfMaxHops=8",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/scalp/v2/cron/execute?dryRun=false",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/scalp/v2/cron/reconcile",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/scalp/v2/cron/load-candles?batchSize=4&autoSuccessor=true&autoContinue=true&selfMaxHops=20&successor=discover",
      "schedule": "10 */2 * * *"
    },
    {
      "path": "/api/scalp/v5/cron/evaluate?limit=50",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/scalp/v5/cron/promote",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/scalp/v5/cron/sunday-rollover",
      "schedule": "0 2 * * 0"
    },
    {
      "path": "/api/scalp/v5/cron/trim-tail",
      "schedule": "0 6 * * 0"
    }
  ]
}
