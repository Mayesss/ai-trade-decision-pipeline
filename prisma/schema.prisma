generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ScalpJobKind {
  EXECUTE_CYCLE      @map("execute_cycle")
  RESEARCH_TASK      @map("research_task")
  RESEARCH_AGGREGATE @map("research_aggregate")
  PROMOTION_SYNC     @map("promotion_sync")
  GUARDRAIL_CHECK    @map("guardrail_check")
  HOUSEKEEPING       @map("housekeeping")

  @@map("scalp_job_kind")
}

enum ScalpJobStatus {
  PENDING          @map("pending")
  RUNNING          @map("running")
  RETRY_WAIT       @map("retry_wait")
  SUCCEEDED        @map("succeeded")
  FAILED_PERMANENT @map("failed_permanent")
  CANCELLED        @map("cancelled")

  @@map("scalp_job_status")
}

enum ScalpShadowJobOutcome {
  PROCESSED @map("processed")
  SKIPPED   @map("skipped")

  @@map("scalp_shadow_job_outcome")
}

model ScalpDeployment {
  deploymentId   String    @id @map("deployment_id")
  symbol         String
  strategyId     String    @map("strategy_id")
  tuneId         String    @map("tune_id")
  entrySessionProfile String @default("berlin") @map("entry_session_profile")
  source         String
  enabled        Boolean   @default(false)
  configOverride Json      @default(dbgenerated("'{}'::jsonb")) @map("config_override") @db.JsonB
  promotionGate  Json?     @map("promotion_gate") @db.JsonB
  inUniverse     Boolean   @default(true) @map("in_universe")
  workerDirty    Boolean   @default(false) @map("worker_dirty")
  promotionDirty Boolean   @default(false) @map("promotion_dirty")
  retiredAt      DateTime? @map("retired_at") @db.Timestamptz(3)
  lastPreparedAt DateTime? @map("last_prepared_at") @db.Timestamptz(3)
  updatedBy      String?   @map("updated_by")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime  @default(now()) @map("updated_at") @db.Timestamptz(3)

  sessions        ScalpSession[]
  executionRuns   ScalpExecutionRun[]
  tradeLedgerRows ScalpTradeLedger[]
  weeklyMetrics   ScalpDeploymentWeeklyMetric[]

  @@unique([symbol, strategyId, tuneId], map: "scalp_deployments_unique_triplet")
  @@index([enabled], map: "scalp_deployments_enabled_idx")
  @@index([entrySessionProfile], map: "scalp_deployments_entry_session_profile_idx")
  @@index([entrySessionProfile, symbol], map: "scalp_deployments_session_symbol_idx")
  @@index([inUniverse], map: "scalp_deployments_in_universe_idx")
  @@index([workerDirty], map: "scalp_deployments_worker_dirty_idx")
  @@index([promotionDirty], map: "scalp_deployments_promotion_dirty_idx")
  @@map("scalp_deployments")
}

model ScalpRuntimeSetting {
  singleton         Boolean  @id @default(true)
  defaultStrategyId String   @map("default_strategy_id")
  envEnabled        Boolean  @default(true) @map("env_enabled")
  updatedBy         String?  @map("updated_by")
  updatedAt         DateTime @default(now()) @map("updated_at") @db.Timestamptz(3)

  @@map("scalp_runtime_settings")
}

model ScalpStrategyOverride {
  strategyId String   @id @map("strategy_id")
  kvEnabled  Boolean? @map("kv_enabled")
  updatedBy  String?  @map("updated_by")
  updatedAt  DateTime @default(now()) @map("updated_at") @db.Timestamptz(3)

  @@map("scalp_strategy_overrides")
}

model ScalpSession {
  deploymentId    String   @map("deployment_id")
  dayKey          DateTime @map("day_key") @db.Date
  stateJson       Json     @map("state_json") @db.JsonB
  lastReasonCodes String[] @default([]) @map("last_reason_codes")
  updatedAt       DateTime @default(now()) @map("updated_at") @db.Timestamptz(3)

  deployment ScalpDeployment @relation(fields: [deploymentId], references: [deploymentId], onDelete: Cascade)

  @@id([deploymentId, dayKey])
  @@index([updatedAt], map: "scalp_sessions_updated_at_idx")
  @@map("scalp_sessions")
}

model ScalpExecutionRun {
  id              BigInt    @id @default(autoincrement())
  deploymentId    String    @map("deployment_id")
  scheduledMinute DateTime  @map("scheduled_minute") @db.Timestamptz(3)
  status          String
  reasonCodes     String[]  @default([]) @map("reason_codes")
  errorCode       String?   @map("error_code")
  errorMessage    String?   @map("error_message")
  startedAt       DateTime  @default(now()) @map("started_at") @db.Timestamptz(3)
  finishedAt      DateTime? @map("finished_at") @db.Timestamptz(3)

  deployment ScalpDeployment @relation(fields: [deploymentId], references: [deploymentId], onDelete: Cascade)

  @@unique([deploymentId, scheduledMinute], map: "scalp_execution_runs_unique_deployment_minute")
  @@index([scheduledMinute], map: "scalp_execution_runs_scheduled_idx")
  @@map("scalp_execution_runs")
}

model ScalpJournal {
  id           String    @id @db.Uuid
  ts           DateTime  @db.Timestamptz(3)
  deploymentId String?   @map("deployment_id")
  symbol       String?
  dayKey       DateTime? @map("day_key") @db.Date
  level        String
  type         String
  reasonCodes  String[]  @default([]) @map("reason_codes")
  payload      Json      @default(dbgenerated("'{}'::jsonb")) @db.JsonB

  @@index([ts(sort: Desc)], map: "scalp_journal_ts_idx")
  @@index([deploymentId, ts(sort: Desc)], map: "scalp_journal_deployment_idx")
  @@map("scalp_journal")
}

model ScalpTradeLedger {
  id           String   @id @db.Uuid
  exitAt       DateTime @map("exit_at") @db.Timestamptz(3)
  deploymentId String   @map("deployment_id")
  symbol       String
  strategyId   String   @map("strategy_id")
  tuneId       String   @map("tune_id")
  side         String?
  dryRun       Boolean  @default(false) @map("dry_run")
  rMultiple    Decimal  @map("r_multiple") @db.Decimal(20, 8)
  reasonCodes  String[] @default([]) @map("reason_codes")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  deployment ScalpDeployment @relation(fields: [deploymentId], references: [deploymentId])

  @@index([exitAt(sort: Desc)], map: "scalp_trade_ledger_exit_idx")
  @@index([deploymentId, exitAt(sort: Desc)], map: "scalp_trade_ledger_deployment_idx")
  @@map("scalp_trade_ledger")
}

model ScalpSymbolCooldown {
  symbol           String    @id
  failureCount     Int       @default(0) @map("failure_count")
  windowStartedAt  DateTime? @map("window_started_at") @db.Timestamptz(3)
  blockedUntil     DateTime? @map("blocked_until") @db.Timestamptz(3)
  lastErrorCode    String?   @map("last_error_code")
  lastErrorMessage String?   @map("last_error_message")
  cycleId          String?   @map("cycle_id")
  updatedAt        DateTime  @default(now()) @map("updated_at") @db.Timestamptz(3)

  @@index([blockedUntil], map: "scalp_symbol_cooldowns_blocked_idx")
  @@map("scalp_symbol_cooldowns")
}

model ScalpSymbolMarketMetadata {
  symbol              String   @id
  epic                String?
  source              String
  assetCategory       String   @map("asset_category")
  instrumentType      String?  @map("instrument_type")
  marketStatus        String?  @map("market_status")
  pipSize             Decimal  @map("pip_size") @db.Decimal(20, 10)
  pipPosition         Int?     @map("pip_position")
  tickSize            Decimal? @map("tick_size") @db.Decimal(20, 10)
  decimalPlacesFactor Int?     @map("decimal_places_factor")
  scalingFactor       Int?     @map("scaling_factor")
  minDealSize         Decimal? @map("min_deal_size") @db.Decimal(20, 10)
  sizeDecimals        Int?     @map("size_decimals")
  maxLeverage         Int?     @map("max_leverage")
  openingHoursJson    Json?    @map("opening_hours_json") @db.JsonB
  fetchedAt           DateTime @map("fetched_at") @db.Timestamptz(3)
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt           DateTime @default(now()) @map("updated_at") @db.Timestamptz(3)

  @@index([assetCategory, updatedAt(sort: Desc)], map: "scalp_symbol_market_metadata_category_updated_idx")
  @@index([updatedAt(sort: Desc)], map: "scalp_symbol_market_metadata_updated_idx")
  @@map("scalp_symbol_market_metadata")
}

model ScalpSymbolUniverseSnapshot {
  snapshotKey String   @id @map("snapshot_key")
  payloadJson Json     @default(dbgenerated("'{}'::jsonb")) @map("payload_json") @db.JsonB
  generatedAt DateTime @default(now()) @map("generated_at") @db.Timestamptz(3)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime @default(now()) @map("updated_at") @db.Timestamptz(3)

  @@index([updatedAt(sort: Desc)], map: "scalp_symbol_universe_snapshots_updated_idx")
  @@map("scalp_symbol_universe_snapshots")
}

model ScalpJob {
  id           BigInt         @id @default(autoincrement())
  kind         ScalpJobKind
  dedupeKey    String         @map("dedupe_key")
  payload      Json           @default(dbgenerated("'{}'::jsonb")) @db.JsonB
  status       ScalpJobStatus @default(PENDING)
  attempts     Int            @default(0)
  maxAttempts  Int            @default(5) @map("max_attempts")
  scheduledFor DateTime       @default(now()) @map("scheduled_for") @db.Timestamptz(3)
  nextRunAt    DateTime       @default(now()) @map("next_run_at") @db.Timestamptz(3)
  lockedBy     String?        @map("locked_by")
  lockedAt     DateTime?      @map("locked_at") @db.Timestamptz(3)
  lastError    String?        @map("last_error")
  createdAt    DateTime       @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt    DateTime       @default(now()) @map("updated_at") @db.Timestamptz(3)

  @@unique([kind, dedupeKey], map: "scalp_jobs_unique_kind_dedupe")
  @@index([status, nextRunAt, scheduledFor], map: "scalp_jobs_claim_idx")
  @@map("scalp_jobs")
}

model ScalpShadowJobRun {
  id                BigInt                @id @default(autoincrement())
  jobId             BigInt                @map("job_id")
  kind              ScalpJobKind
  dedupeKey         String                @map("dedupe_key")
  workerId          String                @map("worker_id")
  attemptNo         Int                   @map("attempt_no")
  outcome           ScalpShadowJobOutcome
  success           Boolean
  completionApplied Boolean               @default(true) @map("completion_applied")
  errorCode         String?               @map("error_code")
  errorMessage      String?               @map("error_message")
  claimedAt         DateTime              @map("claimed_at") @db.Timestamptz(3)
  finishedAt        DateTime              @map("finished_at") @db.Timestamptz(3)
  durationMs        Int                   @map("duration_ms")
  createdAt         DateTime              @default(now()) @map("created_at") @db.Timestamptz(3)

  @@unique([jobId, attemptNo], map: "scalp_shadow_job_runs_unique_job_attempt")
  @@index([jobId, createdAt(sort: Desc)], map: "scalp_shadow_job_runs_job_created_idx")
  @@index([kind, createdAt(sort: Desc)], map: "scalp_shadow_job_runs_kind_created_idx")
  @@index([success, createdAt(sort: Desc)], map: "scalp_shadow_job_runs_success_created_idx")
  @@index([workerId, createdAt(sort: Desc)], map: "scalp_shadow_job_runs_worker_created_idx")
  @@index([createdAt(sort: Desc)], map: "scalp_shadow_job_runs_created_idx")
  @@map("scalp_shadow_job_runs")
}

model ScalpPipelineJob {
  jobKind       String    @map("job_kind")
  entrySessionProfile String @default("berlin") @map("entry_session_profile")
  status        String    @default("idle")
  lockToken     String?   @map("lock_token")
  lockExpiresAt DateTime? @map("lock_expires_at") @db.Timestamptz(3)
  runningSince  DateTime? @map("running_since") @db.Timestamptz(3)
  nextRunAt     DateTime? @map("next_run_at") @db.Timestamptz(3)
  attempts      Int       @default(0)
  lastRunAt     DateTime? @map("last_run_at") @db.Timestamptz(3)
  lastSuccessAt DateTime? @map("last_success_at") @db.Timestamptz(3)
  lastDurationMs Int?     @map("last_duration_ms")
  lastError     String?   @map("last_error")
  progressLabel String?   @map("progress_label")
  progressJson  Json?     @map("progress_json") @db.JsonB
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt     DateTime  @default(now()) @map("updated_at") @db.Timestamptz(3)

  @@id([jobKind, entrySessionProfile])
  @@index([status], map: "scalp_pipeline_jobs_status_idx")
  @@index([nextRunAt], map: "scalp_pipeline_jobs_next_run_idx")
  @@index([entrySessionProfile, status], map: "scalp_pipeline_jobs_session_status_idx")
  @@index([entrySessionProfile, nextRunAt], map: "scalp_pipeline_jobs_session_next_run_idx")
  @@map("scalp_pipeline_jobs")
}

model ScalpPipelineJobRun {
  id                BigInt    @id @default(autoincrement())
  jobKind           String    @map("job_kind")
  entrySessionProfile String  @default("berlin") @map("entry_session_profile")
  status            String
  startedAt         DateTime  @map("started_at") @db.Timestamptz(3)
  finishedAt        DateTime  @map("finished_at") @db.Timestamptz(3)
  durationMs        Int       @map("duration_ms")
  processed         Int       @default(0)
  succeeded         Int       @default(0)
  retried           Int       @default(0)
  failed            Int       @default(0)
  pendingAfter      Int       @default(0) @map("pending_after")
  downstreamRequested Boolean @default(false) @map("downstream_requested")
  error             String?
  progressLabel     String?   @map("progress_label")
  detailsJson       Json?     @map("details_json") @db.JsonB
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([jobKind, startedAt(sort: Desc)], map: "scalp_pipeline_job_runs_kind_started_idx")
  @@index([finishedAt(sort: Desc)], map: "scalp_pipeline_job_runs_finished_idx")
  @@index([entrySessionProfile, jobKind, startedAt(sort: Desc)], map: "scalp_pipeline_job_runs_session_kind_started_idx")
  @@index([entrySessionProfile, finishedAt(sort: Desc)], map: "scalp_pipeline_job_runs_session_finished_idx")
  @@map("scalp_pipeline_job_runs")
}

model ScalpPipelineSymbol {
  symbol              String    @id
  active              Boolean   @default(true)
  discoverStatus      String    @default("pending") @map("discover_status")
  discoverAttempts    Int       @default(0) @map("discover_attempts")
  discoverNextRunAt   DateTime? @map("discover_next_run_at") @db.Timestamptz(3)
  discoverError       String?   @map("discover_error")
  lastDiscoveredAt    DateTime? @map("last_discovered_at") @db.Timestamptz(3)
  loadStatus          String    @default("pending") @map("load_status")
  loadAttempts        Int       @default(0) @map("load_attempts")
  loadNextRunAt       DateTime? @map("load_next_run_at") @db.Timestamptz(3)
  loadError           String?   @map("load_error")
  weeksCovered        Int       @default(0) @map("weeks_covered")
  latestWeekStart     DateTime? @map("latest_week_start") @db.Timestamptz(3)
  lastLoadedAt        DateTime? @map("last_loaded_at") @db.Timestamptz(3)
  prepareStatus       String    @default("pending") @map("prepare_status")
  prepareAttempts     Int       @default(0) @map("prepare_attempts")
  prepareNextRunAt    DateTime? @map("prepare_next_run_at") @db.Timestamptz(3)
  prepareError        String?   @map("prepare_error")
  preparedDeployments Int       @default(0) @map("prepared_deployments")
  lastPreparedAt      DateTime? @map("last_prepared_at") @db.Timestamptz(3)
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt           DateTime  @default(now()) @map("updated_at") @db.Timestamptz(3)

  @@index([active], map: "scalp_pipeline_symbols_active_idx")
  @@index([loadStatus, loadNextRunAt], map: "scalp_pipeline_symbols_load_claim_idx")
  @@index([prepareStatus, prepareNextRunAt], map: "scalp_pipeline_symbols_prepare_claim_idx")
  @@map("scalp_pipeline_symbols")
}

model ScalpDiscoveredSymbol {
  symbol              String    @id
  lastDiscoveredAt    DateTime? @map("last_discovered_at") @db.Timestamptz(3)
  loadStatus          String    @default("pending") @map("load_status")
  loadAttempts        Int       @default(0) @map("load_attempts")
  loadNextRunAt       DateTime? @map("load_next_run_at") @db.Timestamptz(3)
  loadError           String?   @map("load_error")
  weeksCovered        Int       @default(0) @map("weeks_covered")
  latestWeekStart     DateTime? @map("latest_week_start") @db.Timestamptz(3)
  lastLoadedAt        DateTime? @map("last_loaded_at") @db.Timestamptz(3)
  prepareStatus       String    @default("pending") @map("prepare_status")
  prepareAttempts     Int       @default(0) @map("prepare_attempts")
  prepareNextRunAt    DateTime? @map("prepare_next_run_at") @db.Timestamptz(3)
  prepareError        String?   @map("prepare_error")
  preparedDeployments Int       @default(0) @map("prepared_deployments")
  lastPreparedAt      DateTime? @map("last_prepared_at") @db.Timestamptz(3)
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt           DateTime  @default(now()) @map("updated_at") @db.Timestamptz(3)

  @@index([loadStatus, loadNextRunAt], map: "scalp_discovered_symbols_load_claim_idx")
  @@index([prepareStatus, prepareNextRunAt], map: "scalp_discovered_symbols_prepare_claim_idx")
  @@map("scalp_discovered_symbols")
}

model ScalpDeploymentWeeklyMetric {
  id             BigInt    @id @default(autoincrement())
  deploymentId   String    @map("deployment_id")
  entrySessionProfile String @default("berlin") @map("entry_session_profile")
  symbol         String
  strategyId     String    @map("strategy_id")
  tuneId         String    @map("tune_id")
  weekStart      DateTime  @map("week_start") @db.Timestamptz(3)
  weekEnd        DateTime  @map("week_end") @db.Timestamptz(3)
  status         String    @default("pending")
  attempts       Int       @default(0)
  nextRunAt      DateTime  @default(now()) @map("next_run_at") @db.Timestamptz(3)
  workerId       String?   @map("worker_id")
  startedAt      DateTime? @map("started_at") @db.Timestamptz(3)
  finishedAt     DateTime? @map("finished_at") @db.Timestamptz(3)
  errorCode      String?   @map("error_code")
  errorMessage   String?   @map("error_message")
  trades         Int?      @map("trades")
  winRatePct     Decimal?  @map("win_rate_pct") @db.Decimal(10, 4)
  netR           Decimal?  @map("net_r") @db.Decimal(20, 8)
  expectancyR    Decimal?  @map("expectancy_r") @db.Decimal(20, 8)
  profitFactor   Decimal?  @map("profit_factor") @db.Decimal(20, 8)
  maxDrawdownR   Decimal?  @map("max_drawdown_r") @db.Decimal(20, 8)
  avgHoldMinutes Decimal?  @map("avg_hold_minutes") @db.Decimal(20, 8)
  netPnlUsd      Decimal?  @map("net_pnl_usd") @db.Decimal(20, 8)
  grossProfitR   Decimal?  @map("gross_profit_r") @db.Decimal(20, 8)
  grossLossR     Decimal?  @map("gross_loss_r") @db.Decimal(20, 8)
  metricsJson    Json?     @map("metrics_json") @db.JsonB
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime  @default(now()) @map("updated_at") @db.Timestamptz(3)

  deployment ScalpDeployment @relation(fields: [deploymentId], references: [deploymentId], onDelete: Cascade)

  @@unique([deploymentId, weekStart], map: "scalp_deployment_weekly_metrics_unique_week")
  @@index([status, nextRunAt, weekStart], map: "scalp_deployment_weekly_metrics_claim_idx")
  @@index([entrySessionProfile, status, nextRunAt, weekStart], map: "scalp_deployment_weekly_metrics_session_claim_idx")
  @@index([entrySessionProfile, deploymentId, weekStart(sort: Desc)], map: "scalp_deployment_weekly_metrics_session_deployment_week_idx")
  @@index([deploymentId, weekStart(sort: Desc)], map: "scalp_deployment_weekly_metrics_deployment_week_idx")
  @@index([symbol, strategyId, tuneId, weekStart(sort: Desc)], map: "scalp_deployment_weekly_metrics_symbol_strategy_week_idx")
  @@map("scalp_deployment_weekly_metrics")
}

model ScalpAdaptiveSelectorSnapshot {
  snapshotId          String   @id @map("snapshot_id")
  symbol              String
  entrySessionProfile String   @default("berlin") @map("entry_session_profile")
  strategyId          String   @map("strategy_id")
  status              String   @default("shadow")
  trainedAt           DateTime @map("trained_at") @db.Timestamptz(3)
  windowFromTs        BigInt   @map("window_from_ts")
  windowToTs          BigInt   @map("window_to_ts")
  catalogJson         Json     @default(dbgenerated("'{}'::jsonb")) @map("catalog_json") @db.JsonB
  metricsJson         Json     @default(dbgenerated("'{}'::jsonb")) @map("metrics_json") @db.JsonB
  lockStartedAtMs     BigInt?  @map("lock_started_at_ms")
  lockUntilMs         BigInt?  @map("lock_until_ms")
  baselineMaxDrawdownR Decimal? @map("baseline_max_drawdown_r") @db.Decimal(20, 8)
  updatedBy           String?  @map("updated_by")
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt           DateTime @default(now()) @map("updated_at") @db.Timestamptz(3)

  @@index([symbol, entrySessionProfile, strategyId, status], map: "scalp_adaptive_selector_snapshots_symbol_strategy_status_idx")
  @@index([status, trainedAt(sort: Desc)], map: "scalp_adaptive_selector_snapshots_status_trained_idx")
  @@map("scalp_adaptive_selector_snapshots")
}

model ScalpAdaptiveSelectorDecision {
  id                  BigInt   @id @default(autoincrement())
  ts                  DateTime @default(now()) @db.Timestamptz(3)
  deploymentId        String   @map("deployment_id")
  symbol              String
  strategyId          String   @map("strategy_id")
  entrySessionProfile String   @default("berlin") @map("entry_session_profile")
  snapshotId          String?  @map("snapshot_id")
  selectedArmId       String?  @map("selected_arm_id")
  selectedArmType     String   @default("none") @map("selected_arm_type")
  confidence          Decimal? @db.Decimal(10, 6)
  skipReason          String?  @map("skip_reason")
  reasonCodes         String[] @default([]) @map("reason_codes")
  featuresHash        String?  @map("features_hash")
  detailsJson         Json     @default(dbgenerated("'{}'::jsonb")) @map("details_json") @db.JsonB
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@index([symbol, entrySessionProfile, ts(sort: Desc)], map: "scalp_adaptive_selector_decisions_symbol_session_ts_idx")
  @@index([deploymentId, ts(sort: Desc)], map: "scalp_adaptive_selector_decisions_deployment_ts_idx")
  @@index([snapshotId, ts(sort: Desc)], map: "scalp_adaptive_selector_decisions_snapshot_ts_idx")
  @@map("scalp_adaptive_selector_decisions")
}
